# ─────────────────────────────────────────────────────────────────────────────
# SimpleBuild Pro - Staging Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────

# ─── Application ───────────────────────────────────────────────────────────
NODE_ENV=staging
PORT=8080
APP_VERSION=${GITHUB_SHA}
APP_URL=https://staging.simplebuildpro.com
API_URL=https://api-staging.simplebuildpro.com
LOG_LEVEL=debug

# ─── Database (Cloud SQL - Staging Instance) ─────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@/simplebuildpro_staging?host=/cloudsql/PROJECT:REGION:INSTANCE-staging
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SSL=true

# ─── Redis (Memorystore - Staging) ──────────────────────────────────────
REDIS_URL=redis://10.x.x.x:6379
REDIS_MAX_RETRIES=3

# ─── Authentication ──────────────────────────────────────────────────────
JWT_SECRET=staging-jwt-secret
JWT_REFRESH_SECRET=staging-jwt-refresh-secret
JWT_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_IN=2592000

# ─── OAuth2 (Use test/dev credentials) ──────────────────────────────────
GOOGLE_CLIENT_ID=staging-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=staging-google-client-secret
GITHUB_CLIENT_ID=staging-github-client-id
GITHUB_CLIENT_SECRET=staging-github-client-secret

# ─── Stripe (Test Mode) ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=<your-stripe-test-key>
STRIPE_WEBHOOK_SECRET=<your-stripe-test-webhook-secret>

# ─── AI ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=<your-anthropic-api-key>
AI_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=4096

# ─── Storage (Staging Bucket) ───────────────────────────────────────────
GCS_BUCKET=simplebuildpro-staging-assets
GCS_CDN_URL=https://storage.googleapis.com/simplebuildpro-staging-assets

# ─── Novita ──────────────────────────────────────────────────────────────
NOVITA_API_KEY=staging-novita-key
NOVITA_SANDBOX_TIMEOUT=900

# ─── PageSpeed ───────────────────────────────────────────────────────────
PAGESPEED_API_KEY=staging-pagespeed-key
