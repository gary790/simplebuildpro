# ─────────────────────────────────────────────────────────────────────────────
# SimpleBuild Pro - Production Environment Configuration
# These values are set via Google Cloud Secret Manager
# This file documents the expected environment variables for production
# ─────────────────────────────────────────────────────────────────────────────

# ─── Application ───────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080
APP_VERSION=${GITHUB_SHA}
APP_URL=https://app.simplebuildpro.com
API_URL=https://api.simplebuildpro.com
LOG_LEVEL=info

# ─── Database (Cloud SQL PostgreSQL 16) ───────────────────────────────────
# Set via Secret Manager: simplebuildpro-database-url
# Format: postgresql://USER:PASSWORD@/simplebuildpro?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=<from-secret-manager>
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_SSL=true

# ─── Redis (Memorystore) ─────────────────────────────────────────────────
# Set via Secret Manager: simplebuildpro-redis-url
REDIS_URL=<from-secret-manager>
REDIS_MAX_RETRIES=5

# ─── Authentication ──────────────────────────────────────────────────────
# Set via Secret Manager
JWT_SECRET=<from-secret-manager>
JWT_REFRESH_SECRET=<from-secret-manager>
JWT_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_IN=2592000

# ─── OAuth2 ──────────────────────────────────────────────────────────────
# Set via Secret Manager
GOOGLE_CLIENT_ID=<from-secret-manager>
GOOGLE_CLIENT_SECRET=<from-secret-manager>
GITHUB_CLIENT_ID=<from-secret-manager>
GITHUB_CLIENT_SECRET=<from-secret-manager>

# ─── Stripe ──────────────────────────────────────────────────────────────
# Set via Secret Manager
STRIPE_SECRET_KEY=<from-secret-manager>
STRIPE_WEBHOOK_SECRET=<from-secret-manager>

# ─── AI ──────────────────────────────────────────────────────────────────
# Set via Secret Manager
ANTHROPIC_API_KEY=<from-secret-manager>
AI_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=4096

# ─── Storage ─────────────────────────────────────────────────────────────
GCS_BUCKET=simplebuildpro-production-assets
GCS_CDN_URL=https://cdn.simplebuildpro.com

# ─── Novita ──────────────────────────────────────────────────────────────
NOVITA_API_KEY=<from-secret-manager>
NOVITA_SANDBOX_TIMEOUT=1800

# ─── PageSpeed ───────────────────────────────────────────────────────────
PAGESPEED_API_KEY=<from-secret-manager>
