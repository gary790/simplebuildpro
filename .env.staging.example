# ─────────────────────────────────────────────────────────────────────────────
# SimpleBuild Pro — Staging Environment Template
# ─────────────────────────────────────────────────────────────────────────────

# ─── Server ────────────────────────────────────────────────────────────
NODE_ENV=staging
PORT=8080
APP_VERSION=1.0.0-staging

# ─── URLs ──────────────────────────────────────────────────────────────
APP_URL=https://staging-app.simplebuildpro.com
API_URL=https://staging-api.simplebuildpro.com

# ─── Database (Cloud SQL Staging Instance) ────────────────────────────
DATABASE_URL=postgresql://simplebuild:PASSWORD@/simplebuildpro_staging?host=/cloudsql/simplebuildpro:us-central1:simplebuildpro-db-staging

# ─── Redis (Memorystore Staging) ──────────────────────────────────────
REDIS_URL=redis://10.0.0.4:6379

# ─── Authentication ───────────────────────────────────────────────────
JWT_SECRET=staging-jwt-secret-change-me
JWT_REFRESH_SECRET=staging-jwt-refresh-secret-change-me
JWT_EXPIRY=900
JWT_REFRESH_EXPIRY=2592000

# ─── OAuth Providers (Test/Dev Credentials) ───────────────────────────
GOOGLE_CLIENT_ID=staging-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=staging-google-client-secret
GITHUB_CLIENT_ID=staging-github-client-id
GITHUB_CLIENT_SECRET=staging-github-client-secret

# ─── Stripe (Test Keys) ──────────────────────────────────────────────
STRIPE_SECRET_KEY=<your-stripe-test-key>
STRIPE_WEBHOOK_SECRET=<your-stripe-test-webhook-secret>

# ─── AI (Anthropic Claude) ────────────────────────────────────────────
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# ─── Storage (Google Cloud Storage — Staging Bucket) ──────────────────
GCS_BUCKET=simplebuildpro-assets-staging

# ─── Preview (Novita Sandbox) ─────────────────────────────────────────
NOVITA_API_KEY=your-novita-api-key

# ─── Lighthouse (PageSpeed Insights) ─────────────────────────────────
PAGESPEED_API_KEY=your-pagespeed-api-key

# ─── GCP Configuration ────────────────────────────────────────────────
GCP_PROJECT_ID=simplebuildpro
GCP_REGION=us-central1
CLOUD_SQL_CONNECTION_NAME=simplebuildpro:us-central1:simplebuildpro-db-staging
