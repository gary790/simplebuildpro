{
  "name": "@simplebuildpro/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/index.mjs --external:@google-cloud/storage --external:sharp --external:pg-native --external:better-sqlite3 --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\" && echo 'API build complete'",
    "start": "node dist/index.mjs",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.14.0",
    "@hono/node-server": "^1.13.0",
    "@simplebuildpro/db": "*",
    "@simplebuildpro/shared": "*",
    "bcryptjs": "^2.4.3",
    "clean-css": "^5.3.3",
    "crypto-js": "^4.2.0",
    "hono": "^4.7.0",
    "html-minifier-terser": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "redis": "^5.12.1",
    "resend": "^6.12.3",
    "sharp": "^0.33.0",
    "stripe": "^22.1.1",
    "terser": "^5.37.0",
    "uuid": "^11.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/clean-css": "^4.2.11",
    "@types/html-minifier-terser": "^7.0.2",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/uuid": "^10.0.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
