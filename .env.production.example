# ─────────────────────────────────────────────────────────────────────────────
# SimpleBuild Pro — Production Environment Template
# Copy to .env and fill in actual values
# ─────────────────────────────────────────────────────────────────────────────

# ─── Server ────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=8080
APP_VERSION=1.0.0

# ─── URLs ──────────────────────────────────────────────────────────────
APP_URL=https://app.simplebuildpro.com
API_URL=https://api.simplebuildpro.com

# ─── Database (Cloud SQL via Private IP) ──────────────────────────────
DATABASE_URL=postgresql://simplebuild:PASSWORD@/simplebuildpro?host=/cloudsql/simplebuildpro:us-central1:simplebuildpro-db

# ─── Redis (Memorystore) ──────────────────────────────────────────────
REDIS_URL=redis://10.0.0.3:6379

# ─── Authentication ───────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_GENERATE_64_CHAR_RANDOM
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_64_CHAR_RANDOM
JWT_EXPIRY=900
JWT_REFRESH_EXPIRY=2592000

# ─── OAuth Providers ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ─── Stripe (Live Keys) ──────────────────────────────────────────────
STRIPE_SECRET_KEY=<from-secret-manager>
STRIPE_WEBHOOK_SECRET=<from-secret-manager>

# ─── AI (Anthropic Claude) ────────────────────────────────────────────
ANTHROPIC_API_KEY=<from-secret-manager>

# ─── Storage (Google Cloud Storage) ───────────────────────────────────
GCS_BUCKET=simplebuildpro-assets

# ─── Preview (Novita Sandbox) ─────────────────────────────────────────
NOVITA_API_KEY=your-novita-api-key

# ─── Lighthouse (PageSpeed Insights) ─────────────────────────────────
PAGESPEED_API_KEY=your-pagespeed-api-key

# ─── GCP Configuration ────────────────────────────────────────────────
GCP_PROJECT_ID=simplebuildpro
GCP_REGION=us-central1
CLOUD_SQL_CONNECTION_NAME=simplebuildpro:us-central1:simplebuildpro-db
