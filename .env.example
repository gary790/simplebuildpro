# ─────────────────────────────────────────────────────────────────────────────
# SimpleBuild Pro — Environment Configuration
# Copy this file to .env and fill in your values
# Last updated: Phase 0.5 (2026-05-09)
# ─────────────────────────────────────────────────────────────────────────────

# ─── Application ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080
APP_VERSION=1.0.0
APP_URL=http://localhost:3000
API_URL=http://localhost:8080
LOG_LEVEL=debug

# ─── Database (PostgreSQL 16) ──────────────────────────────────────────────
DATABASE_URL=postgresql://simplebuild:localdev123@localhost:5432/simplebuildpro
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SSL=false

# ─── Redis (Rate Limiting & Caching) ──────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_MAX_RETRIES=3

# ─── Authentication ───────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-secure-random-string-in-production
JWT_REFRESH_SECRET=change-this-to-another-secure-random-string
JWT_EXPIRY=900
JWT_REFRESH_EXPIRY=2592000

# ─── Encryption (for stored OAuth tokens) ────────────────────────────────
ENCRYPTION_KEY=generate-a-64-char-hex-string-for-aes-256-gcm

# ─── OAuth2: Google ───────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── OAuth2: GitHub (for user login + repo connection) ───────────────────
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ─── OAuth2: Vercel (Ship panel integration) ─────────────────────────────
VERCEL_CLIENT_ID=your-vercel-client-id
VERCEL_CLIENT_SECRET=your-vercel-client-secret

# ─── OAuth2: Netlify (Ship panel integration) ────────────────────────────
NETLIFY_CLIENT_ID=your-netlify-client-id
NETLIFY_CLIENT_SECRET=your-netlify-client-secret

# ─── Stripe (Billing) ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
STRIPE_PRO_PRICE_ID=price_pro_monthly
STRIPE_BUSINESS_PRICE_ID=price_business_monthly

# ─── AI (Anthropic Claude) ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
AI_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=4096

# ─── Google Cloud Storage (Asset uploads) ────────────────────────────────
GCS_BUCKET=simplebuildpro-dev-assets
GCS_CDN_URL=https://storage.googleapis.com/simplebuildpro-dev-assets

# ─── Google Cloud Platform ───────────────────────────────────────────────
GCP_PROJECT_ID=simplebuildpro
GCP_REGION=us-central1
CLOUD_SQL_CONNECTION_NAME=simplebuildpro:us-central1:simplebuildpro-db

# ─── PageSpeed Insights (Lighthouse scores) ──────────────────────────────
PAGESPEED_API_KEY=your-pagespeed-api-key

# ─── Email (Resend) ─────────────────────────────────────────────────────
RESEND_API_KEY=re_your-resend-api-key
FROM_EMAIL=noreply@simplebuildpro.com

# ─── Internal Monitoring ─────────────────────────────────────────────────
INTERNAL_METRICS_TOKEN=a-random-token-for-metrics-endpoint

# ─── Next.js (Web app — must be prefixed NEXT_PUBLIC_) ───────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_APP_URL=http://localhost:3000
