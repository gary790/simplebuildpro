# ============================================================
# SimpleBuild Pro — Environment Variables
# Copy to .env and fill in real values
# NEVER commit .env to version control
# ============================================================

# ─── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://simplebuildpro-app:your-password@localhost:5432/simplebuildpro

# ─── Authentication ────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-at-least-64-characters-long-change-this

# ─── Google Cloud ──────────────────────────────────────────
GCP_PROJECT_ID=simplebuildpro
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json

# ─── GCS Buckets ──────────────────────────────────────────
GCS_BUCKET_ASSETS=simplebuildpro-assets
GCS_BUCKET_BUILDS=simplebuildpro-builds
GCS_BUCKET_DEPLOYS=simplebuildpro-deploys
GCS_BUCKET_SNAPSHOTS=simplebuildpro-snapshots

# ─── CDN ───────────────────────────────────────────────────
CDN_URL=https://cdn.simplebuildpro.com

# ─── Stripe ───────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_IDS={"pro_monthly":"price_xxx","pro_yearly":"price_xxx","business_monthly":"price_xxx","business_yearly":"price_xxx"}

# ─── Anthropic (AI) ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ─── Novita (Preview Sandbox) ────────────────────────────
NOVITA_API_KEY=your-novita-api-key

# ─── App URLs ─────────────────────────────────────────────
APP_URL=https://simplebuildpro.com
API_URL=https://api.simplebuildpro.com
SITES_DOMAIN=sites.simplebuildpro.com

# ─── Next.js Frontend ────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Server ───────────────────────────────────────────────
PORT=8080
NODE_ENV=development
