# ─────────────────────────────────────────────────────────────────────────────
# SimpleBuild Pro - Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ─── Application ───────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080
APP_VERSION=1.0.0
APP_URL=http://localhost:3000
API_URL=http://localhost:8080
LOG_LEVEL=debug

# ─── Database (PostgreSQL 16) ──────────────────────────────────────────────
DATABASE_URL=postgresql://simplebuild:localdev123@localhost:5432/simplebuildpro
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SSL=false

# ─── Redis (Rate Limiting & Caching) ──────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_MAX_RETRIES=3

# ─── Authentication ───────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-secure-random-string-in-production
JWT_REFRESH_SECRET=change-this-to-another-secure-random-string
JWT_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_IN=2592000

# ─── OAuth2: Google ───────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── OAuth2: GitHub ───────────────────────────────────────────────────────
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ─── Stripe (Billing) ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=<your-stripe-secret-key>
STRIPE_WEBHOOK_SECRET=<your-stripe-webhook-secret>
STRIPE_PRO_PRICE_ID=price_pro_monthly
STRIPE_BUSINESS_PRICE_ID=price_business_monthly

# ─── AI (Anthropic Claude) ───────────────────────────────────────────────
ANTHROPIC_API_KEY=<your-anthropic-api-key>
AI_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=4096

# ─── Google Cloud Storage ────────────────────────────────────────────────
GCS_BUCKET=simplebuildpro-dev-assets
GCS_CDN_URL=https://storage.googleapis.com/simplebuildpro-dev-assets

# ─── Novita (Live Preview Sandboxes) ────────────────────────────────────
NOVITA_API_KEY=your-novita-api-key
NOVITA_SANDBOX_TIMEOUT=1800

# ─── PageSpeed Insights (Lighthouse) ────────────────────────────────────
PAGESPEED_API_KEY=your-pagespeed-api-key

# ─── Email (optional - for invitations) ─────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# FROM_EMAIL=noreply@simplebuildpro.com
